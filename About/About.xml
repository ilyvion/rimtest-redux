<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
    <packageId>ilyvion.rimtestredux</packageId>
    <url>https://github.com/ilyvion/rimtest-redux</url>
    <name>RimTest Redux</name>
    <author>ilyvion, LaTrissTitude</author>
    <description>Finally we have unit tests for RimWorld modding! No more manual testing your mods on development, this mod automates the testing process by introducing a testing framework that allows you to test your mods in a simple and easy way. You can save your time and energy, let your computer do the testing for you.</description>
